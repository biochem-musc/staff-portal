<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MUSC Staff Portal</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        /* Hide scrollbar for tabs */
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        /* Simple fade-in animation */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.4s ease-out forwards;
        }
    </style>
</head>
<body class="min-h-screen bg-stone-50 font-sans text-stone-800 selection:bg-amber-200">

    <!-- Header Area -->
    <header class="bg-gradient-to-r from-amber-600 to-orange-500 text-white shadow-lg">
        <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
            <h1 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">Welcome to MUSC Staff Portal</h1>
            <p class="text-amber-50 text-lg max-w-2xl">
                Everything you need, gathered in one place. Explore HR services, research grants, IT systems, and facilities below.
            </p>
            
            <!-- Search Bar -->
            <div class="mt-8 relative max-w-xl">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <i data-lucide="search" class="h-5 w-5 text-stone-400"></i>
                </div>
                <input
                    type="text"
                    id="searchInput"
                    class="block w-full pl-11 pr-4 py-3.5 border-none rounded-2xl text-stone-800 bg-white shadow-md focus:ring-4 focus:ring-amber-300 focus:outline-none transition-all"
                    placeholder="Search for systems, forms, grants..."
                />
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-8">
        
        <!-- Navigation Tabs Container -->
        <div id="tabsContainer" class="flex overflow-x-auto pb-4 mb-6 space-x-2 scrollbar-hide">
            <!-- Tabs will be injected here via JS -->
        </div>

        <!-- Content Area -->
        <div id="contentContainer" class="space-y-12">
            <!-- Categories and Cards will be injected here via JS -->
        </div>

        <!-- No Results Area -->
        <div id="noResults" class="hidden text-center py-20 px-4">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-stone-100 mb-4">
                <i data-lucide="search" class="w-8 h-8 text-stone-400"></i>
            </div>
            <h3 class="text-xl font-semibold text-stone-700 mb-2">No results found</h3>
            <p class="text-stone-500" id="noResultsText">We couldn't find any resources matching your search.</p>
            <button 
                id="clearSearchBtn"
                class="mt-6 px-6 py-2 bg-white border border-stone-200 rounded-xl text-stone-600 hover:bg-stone-50 transition-colors font-medium shadow-sm"
            >
                Clear Search
            </button>
        </div>

    </main>

    <footer class="mt-20 border-t border-stone-200 bg-white py-8">
        <div class="max-w-6xl mx-auto px-4 text-center text-stone-400 text-sm">
            <p id="copyrightText"></p>
        </div>
    </footer>

    <script>
        // Data Configuration
        const portalData = [
            {
                id: 'it',
                title: 'IT Systems',
                icon: 'monitor',
                items: [
                    { name: 'MUSC Intranet Systems', desc: 'MUSC-Personal, MUSC-LEAVE, TQF Management, SmartExam, and e-Payroll', link: 'http://database.sc.mahidol/', icon: 'globe' },
                    { name: 'MU Internet Account', desc: 'Request Internet Account (Fill form, print, and submit to Admin office)', link: 'https://myinternet.mahidol.ac.th/', icon: 'wifi' },
                    { name: 'E-Office', desc: 'System for receiving, sending, and tracking circular letters', link: 'https://eoffice.mahidol.ac.th/api/auth/login', icon: 'mail' }
                ]
            },
            {
                id: 'hr',
                title: 'HR & Welfare',
                icon: 'users',
                items: [
                    { name: 'HR Connect', desc: 'Request employment certificate and submit Flexible Benefit claims', link: 'https://muhr.mahidol.ac.th/HRconnect_new/', icon: 'heart-pulse' },
                    { name: 'Staff ID Card', desc: 'Send a polite photo (plain background) to "Mod" to request an ID card', link: null, icon: 'badge-help', isInfo: true },
                    { name: 'Government Official ID Card', desc: 'System to request a government official ID card', link: 'https://science.mahidol.ac.th/scad/?page_id=797', icon: 'file-text' },
                    { name: 'Parking Permit', desc: 'Download parking permit application form', link: 'https://science.mahidol.ac.th/scad/wp-content/uploads/2023/02/ฟอร์มขอบัตรจอดรถ.pdf', icon: 'car' },
                    { name: 'MU Savings Cooperative', desc: 'Get the form and submit application at Ramathibodi branch', link: 'https://www.si.mahidol.ac.th/musaving/index.asp', icon: 'hand-coins' },
                    { name: 'Provident Fund', desc: 'Provident fund information for staff', link: 'https://science.mahidol.ac.th/scad/?page_id=1311', icon: 'credit-card' },
                    { name: 'Academic Title Request', desc: 'Regulations and procedures for requesting academic titles', link: 'https://science.mahidol.ac.th/scad/?page_id=501', icon: 'graduation-cap' },
                    { name: 'MUSC Group Health Insurance', desc: 'Contact internal extension: 1783 for inquiries', link: null, icon: 'activity', isInfo: true }
                ]
            },
            {
                id: 'research',
                title: 'Research & Grants',
                icon: 'flask-conical',
                items: [
                    { name: 'Research & Grants Portal', desc: 'Central portal for MUSC research and grant information', link: 'https://research.sc.mahidol.ac.th/', icon: 'microscope' },
                    { name: 'Faculty of Science Research Initiative Grant', desc: '150,000 THB/year (up to 2 years). Subject to internal review.', link: 'http://intranet.sc.mahidol/re/form/OK-08-2566.pdf', icon: 'briefcase' },
                    { name: 'Faculty of Science Equipment Grant', desc: '300,000 THB one-time payment for young faculty.', link: 'http://intranet.sc.mahidol/re/form/Young%20Faculty%20Equipment%20Grant-2567.pdf', icon: 'monitor' },
                    { name: 'Mahidol Strategic Grant (Tier 1)', desc: '750,000 THB / 18 months for Junior level researchers.', link: 'https://research.sc.mahidol.ac.th/mugrant/', icon: 'building-2' },
                    { name: 'Article Processing Charge (APC)', desc: '150,000 THB/article in Q1 (No limit per year for first/corresponding author).', link: 'https://op.mahidol.ac.th/ra/budget-pub/', icon: 'file-check-2' },
                    { name: 'Publication Reward (MUSC)', desc: 'Honorary awards for research publications', link: 'https://research.sc.mahidol.ac.th/pubaward/', icon: 'graduation-cap' },
                    { name: 'Fundamental Fund (FF)', desc: 'Basic research funding support (Government)', link: 'https://research.sc.mahidol.ac.th/government_fund/', icon: 'hand-coins' },
                    { name: 'Human & Animal Ethics', desc: 'Submission system for human and animal research ethics', link: 'https://research.sc.mahidol.ac.th/human-ethics/', icon: 'heart-pulse' },
                    { name: 'Biosafety Regulations (BSL2)', desc: 'Annual training announcements, required for grant submissions', link: 'https://research.sc.mahidol.ac.th/biosafety/', icon: 'leaf' },
                    { name: 'SCBC Consumable Quota / CIF Grant / Monthly Stipend', desc: 'Monthly extra stipend available if salary <= 41,000/mo. Check departments for consumable quota & CIF grants.', link: null, icon: 'badge-help', isInfo: true }
                ]
            },
            {
                id: 'facilities',
                title: 'Training & Facilities',
                icon: 'book-open',
                items: [
                    { name: 'MUX (Online Courses & PDPA)', desc: 'PDPA and other university online training courses', link: 'https://mux.mahidol.ac.th/', icon: 'book-open' },
                    { name: 'About Biochemistry Dept.', desc: 'Information about the Biochemistry Department', link: 'https://biochemistry.sc.mahidol.ac.th/', icon: 'building-2' },
                    { name: 'Room & Equipment Booking', desc: 'Room and equipment booking system (New staff contact K. Nadtaya Mongkol for account)', link: 'https://biochemistry.sc.mahidol.ac.th/bc-facilities/', icon: 'monitor' },
                    { name: 'Sports Complex Membership', desc: 'Apply for Faculty of Science sports complex membership', link: 'https://science.mahidol.ac.th/scad/?page_id=1053', icon: 'activity' }
                ]
            }
        ];

        // State
        let activeTab = portalData[0].id;
        let searchQuery = '';

        // DOM Elements
        const tabsContainer = document.getElementById('tabsContainer');
        const contentContainer = document.getElementById('contentContainer');
        const searchInput = document.getElementById('searchInput');
        const noResults = document.getElementById('noResults');
        const noResultsText = document.getElementById('noResultsText');
        const clearSearchBtn = document.getElementById('clearSearchBtn');

        // Set Copyright Year
        document.getElementById('copyrightText').innerText = `© ${new Date().getFullYear()} Faculty of Science, Mahidol University. Internal Staff Portal.`;

        // Render Tabs
        function renderTabs() {
            if (searchQuery) {
                tabsContainer.classList.add('hidden');
                return;
            }
            tabsContainer.classList.remove('hidden');
            
            tabsContainer.innerHTML = portalData.map(category => `
                <button 
                    onclick="setActiveTab('${category.id}')"
                    class="flex items-center whitespace-nowrap px-5 py-3 rounded-xl font-medium transition-all ${
                        activeTab === category.id
                            ? 'bg-amber-100 text-amber-800 shadow-sm border border-amber-200'
                            : 'bg-white text-stone-600 hover:bg-stone-100 border border-transparent'
                    }"
                >
                    <i data-lucide="${category.icon}" class="w-5 h-5 mr-2"></i>
                    ${category.title}
                </button>
            `).join('');
        }

        // Render Cards inside Content Area
        function renderContent() {
            let dataToRender = [];

            if (searchQuery) {
                const lowerQuery = searchQuery.toLowerCase();
                dataToRender = portalData.map(category => ({
                    ...category,
                    items: category.items.filter(item => 
                        item.name.toLowerCase().includes(lowerQuery) || 
                        item.desc.toLowerCase().includes(lowerQuery)
                    )
                })).filter(category => category.items.length > 0);
            } else {
                const activeCategory = portalData.find(c => c.id === activeTab);
                if (activeCategory) dataToRender = [activeCategory];
            }

            // Handle Empty State
            if (searchQuery && dataToRender.length === 0) {
                contentContainer.innerHTML = '';
                noResults.classList.remove('hidden');
                noResultsText.innerText = `We couldn't find any resources matching "${searchQuery}".`;
                lucide.createIcons();
                return;
            }

            noResults.classList.add('hidden');

            // Generate HTML for categories and cards
            contentContainer.innerHTML = dataToRender.map(category => `
                <section class="animate-fade-in">
                    ${searchQuery ? `
                        <h2 class="text-xl font-semibold mb-6 flex items-center text-stone-700 border-b border-stone-200 pb-2">
                            <i data-lucide="${category.icon}" class="w-5 h-5 text-amber-600 mr-2"></i>
                            ${category.title}
                        </h2>
                    ` : ''}
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        ${category.items.map(item => `
                            <${item.isInfo ? 'div' : `a href="${item.link}" target="_blank" rel="noopener noreferrer"`}
                                class="group relative flex flex-col p-6 bg-white rounded-2xl border border-stone-200 shadow-sm hover:shadow-xl transition-all duration-300 ${item.isInfo ? 'cursor-default' : 'cursor-pointer hover:-translate-y-1 hover:border-amber-300'}"
                            >
                                <div class="flex items-start justify-between mb-4">
                                    <div class="p-3 bg-amber-50 text-amber-600 rounded-xl group-hover:bg-amber-100 transition-colors">
                                        <i data-lucide="${item.icon}" class="w-6 h-6"></i>
                                    </div>
                                    ${!item.isInfo ? `
                                        <i data-lucide="chevron-right" class="w-5 h-5 text-stone-300 group-hover:text-amber-500 transition-colors"></i>
                                    ` : ''}
                                </div>
                                <h3 class="text-lg font-semibold text-stone-800 mb-2 leading-snug group-hover:text-amber-700 transition-colors">
                                    ${item.name}
                                </h3>
                                <p class="text-sm text-stone-500 leading-relaxed flex-grow">
                                    ${item.desc}
                                </p>
                                ${item.isInfo ? `
                                    <div class="mt-4 pt-4 border-t border-stone-100 text-xs font-medium text-stone-400 uppercase tracking-wider flex items-center">
                                        <i data-lucide="badge-help" class="w-3 h-3 mr-1"></i>
                                        Information Only
                                    </div>
                                ` : ''}
                            </${item.isInfo ? 'div' : 'a'}>
                        `).join('')}
                    </div>
                </section>
            `).join('');

            // Re-initialize icons for newly injected HTML
            lucide.createIcons();
        }

        // Action Handlers
        window.setActiveTab = function(tabId) {
            activeTab = tabId;
            renderTabs();
            renderContent();
        };

        searchInput.addEventListener('input', (e) => {
            searchQuery = e.target.value.trim();
            renderTabs();
            renderContent();
        });

        clearSearchBtn.addEventListener('click', () => {
            searchQuery = '';
            searchInput.value = '';
            renderTabs();
            renderContent();
        });

        // Initial Render
        renderTabs();
        renderContent();

        // Initialize icons for static HTML (like search bar)
        lucide.createIcons();

    </script>
</body>
</html>
